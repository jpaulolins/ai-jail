# ai-jail sandbox configuration
# https://github.com/akitaonrails/ai-jail
# Edit freely. Regenerate with: ai-jail --clean --init

command = [
    "bash",
    "-lc",
    "echo NORMAL_OK >/dev/null; echo NORMAL_DONE",
]
rw_maps = [
    "/home/akitaonrails/Projects/homebrew-tap",
    "/home/akitaonrails/Projects/ai-jail",
]
ro_maps = []
